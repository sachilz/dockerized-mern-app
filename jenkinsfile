pipeline {
    agent any

    environment {
        GITLEAKS_PATH = "C:\\DevSecOps\\gitleaks\\gitleaks.exe"
        SONAR_SCANNER = "C:\\DevSecOps\\sonar-scanner\\bin\\sonar-scanner.bat"
        TRIVY_PATH = "C:\\DevSecOps\\trivy\\trivy.exe"
    }

    stages {

        // 1. SOURCE CODE
        stage('Checkout') {
            steps {
                git branch: 'main',
                url: 'https://github.com/sachilz/dockerized-mern-app'
            }
        }

        stage('List Files') {
            steps {
                bat 'dir'
            }
        }

        // 2. SECRET SCAN (EARLY - SHIFT LEFT SECURITY)
        stage('Gitleaks Secret Scan') {
            steps {
                bat "\"${GITLEAKS_PATH}\" detect --source . --verbose"
            }
        }

        // 3. INSTALL + BUILD VALIDATION
        stage('Build Validation') {
            steps {
                dir('backend') {
                    bat 'npm install'
                }

                dir('frontend') {
                    bat 'npm install'
                    bat 'npm run build'
                }
            }
        }

        // 4. SAST SCAN (SONARQUBE)
        stage('SonarQube Scan') {
            steps {
                withSonarQubeEnv('sonarqube') {
                    withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
                        bat """
                        \"${SONAR_SCANNER}\" ^
                        -Dsonar.projectKey=dockerized-mern-app ^
                        -Dsonar.sources=. ^
                        -Dsonar.host.url=http://localhost:9000 ^
                        -Dsonar.login=%SONAR_TOKEN%
                        """
                    }
                }
            }
        }
        

        /* 5. QUALITY GATE (IMPORTANT BLOCKER)
        stage('Quality Gate') {
            steps {
                timeout(time: 20, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }
        */

        // 6. DOCKERFILE SECURITY SCAN (HADOLINT)
        stage('Hadolint - Backend Dockerfile') {
            steps {
                dir('backend') {
                    bat "docker run --rm -i hadolint/hadolint < Dockerfile"
                }
            }
        }

        stage('Hadolint - Frontend Dockerfile') {
            steps {
                dir('frontend') {
                    bat "docker run --rm -i hadolint/hadolint < Dockerfile"
                }
            }
        }

        // 7. DOCKER IMAGE BUILD
        stage('Docker Compose Build') {
            steps {
                bat 'docker compose build'
            }
        }

        // 8. IMAGE SECURITY SCAN (AFTER BUILD)
        stage('Trivy Container Scan') {
            steps {
                bat "\"${TRIVY_PATH}\" image --severity HIGH,CRITICAL dockerized-mern-app-backend"
                bat "\"${TRIVY_PATH}\" image --severity HIGH,CRITICAL dockerized-mern-app-frontend"
            }
        }

        // 9. DEPLOYMENT CONFIG (BEFORE RUN)
        stage('Inject Env File') {
            steps {
                withCredentials([file(credentialsId: 'env-file', variable: 'ENV_FILE')]) {
                    bat "copy \"%ENV_FILE%\" backend\\.env"
                }
            }
        }

        // 10. RUN APPLICATION
        stage('Run Containers') {
            steps {
                bat 'docker compose up -d'
            }
        }
    }
}