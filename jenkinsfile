pipeline {
    agent any

    environment {
        GITLEAKS_PATH = "C:\\DevSecOps\\gitleaks\\gitleaks.exe"
        SONAR_SCANNER = "C:\\DevSecOps\\sonar-scanner\\bin\\sonar-scanner.bat"
        TRIVY_PATH = "C:\\DevSecOps\\trivy\\trivy.exe"
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                url: 'https://github.com/sachilz/dockerized-mern-app'
            }
        }

        stage('List Files') {
            steps {
                bat 'dir'
            }
        }

        stage('Gitleaks Secret Scan') {
            steps {
                bat "\"${GITLEAKS_PATH}\" detect --source . --verbose"
            }
        }

        stage('SonarQube Scan') {
            steps {
                withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
                    bat """
                    \"${SONAR_SCANNER}\" ^
                    -Dsonar.projectKey=dockerized-mern-app ^
                    -Dsonar.sources=. ^
                    -Dsonar.host.url=http://localhost:9000 ^
                    -Dsonar.token=%SONAR_TOKEN%
                    """
                }
            }
        }

        stage('Build Validation') {
            steps {
                dir('backend') {
                bat 'npm install'
            }

                dir('frontend') {
                    bat 'npm install'
                    bat 'npm run build'
                }
            }
        }
        
        stage('Docker Compose Build') {
            steps {
                bat 'docker compose build'
            }
        }

        stage('Trivy Container Scan') {
            steps {
                bat "\"${TRIVY_PATH}\" image --severity HIGH,CRITICAL dockerized-mern-app-backend"
                bat "\"${TRIVY_PATH}\" image --severity HIGH,CRITICAL dockerized-mern-app-frontend"
            }
        }

        stage('Inject Env File') {
            steps {
                withCredentials([file(credentialsId: 'env-file', variable: 'ENV_FILE')]) {
                bat "copy \"%ENV_FILE%\" .env"
                }
            }
        }
        
        stage('Run Containers') {
            steps {
                bat 'docker compose up -d'
            }
        }
    }
}
